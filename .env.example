# Contraseña única de acceso a la app
APP_PASSWORD=cambiame

# Secreto para firmar la cookie de sesión. Genera uno con: openssl rand -hex 32
SESSION_SECRET=

# Token para el endpoint MCP (/mcp). Genera uno con: openssl rand -hex 32
# Si lo dejas vacío, el MCP queda deshabilitado.
MCP_TOKEN=

# Puerto del servidor (por defecto 8787)
PORT=8787

# Zona horaria para los avisos de la agenda (importante en Docker, cuya base es UTC)
TZ=Europe/Madrid

# Remitente VAPID para Web Push (opcional; mailto: o https:)
# VAPID_SUBJECT=mailto:tu@email.com

# Carpeta de datos: vault de .md, fotos y db.sqlite (por defecto ./data; en Docker, /data)
# DATA_DIR=./data
