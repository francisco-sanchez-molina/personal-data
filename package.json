{
  "name": "personal-vault",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently -k -n api,web -c magenta,cyan \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server/index.mjs",
    "start": "node dist/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:icons": "node scripts/build-icons.mjs",
    "docker:build": "docker build -t personal-vault:local .",
    "docker:run": "docker run --rm -p 8787:8787 -v $(pwd)/data:/data --env-file .env personal-vault:local"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.1",
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.29",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.43.6",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.0.0",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "dompurify": "^3.2.0",
    "esbuild": "^0.25.0",
    "marked": "^16.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
